# Slack app-level token for Socket Mode (xapp-...)
SLACK_APP_TOKEN=

# Slack bot user OAuth token, used for slash commands and App Home (xoxb-...)
SLACK_BOT_TOKEN=

# Slack user OAuth token, used to set the human user's status/presence/DND (xoxp-...)
# Required — bot tokens cannot write to a user's profile or DND.
SLACK_USER_TOKEN=

# Your Slack user ID (starts with 'U', e.g. 'U0123ABCD'). The service rejects
# slash commands, App Home interactions, and modal submissions from any other
# workspace member. Find it in Slack: Profile → ... → Copy member ID.
SLACK_OWNER_USER_ID=

# Google Calendar service-account credentials JSON (raw content, single line).
# Create in Google Cloud Console -> IAM & Admin -> Service Accounts -> Keys.
GOOGLE_CALENDAR_CREDENTIALS_JSON=

# Google Calendar ID to read events from. Use `primary` for the default calendar,
# or paste the ID from Google Calendar settings -> Integrate calendar -> Calendar ID.
GOOGLE_CALENDAR_ID=primary

# Resolver tick interval (Go duration format: 30s, 1m, 2m30s). Must be >= 1s.
TICK_INTERVAL=30s

# SQLite database file path (absolute, inside the container).
DATABASE_PATH=/data/presence.db

# Log level: debug | info | warn | error
LOG_LEVEL=info
